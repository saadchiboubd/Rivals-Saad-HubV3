-- [[ RIVALS ULTIMATE HUB | FIXED V3 ]] --

-- وظيفة التحميل الآمن للمكتبة
local function SafeLoad(url)
    local success, result = pcall(function()
        return loadstring(game:HttpGet(url))()
    end)
    if success then return result end
    return nil
end

-- محاولة تحميل Rayfield بروابط بديلة
local Rayfield = SafeLoad('https://raw.githubusercontent.com/shlexware/Rayfield/main/source') or 
                 SafeLoad('https://sirius.menu/rayfield')

if not Rayfield then
    warn("فشل تحميل المكتبة! تأكد من جودة الاتصال أو تحديث محرك Velocity.")
    return
end

-- [[ إنشاء الواجهة مع التحقق ]]
local Window = Rayfield:CreateWindow({
   Name = "SAAD BLASTR | RIVALS GOD MODE",
   LoadingTitle = "جاري تفعيل أنظمة الخارق...",
   LoadingSubtitle = "Velocity Fix Edition",
   ConfigurationSaving = { Enabled = false }
})

-- [[ إعدادات الـ Global ]]
getgenv().SilentAimEnabled = false
getgenv().FOVRadius = 150
getgenv().ShowFOV = true
getgenv().AimbotHitbox = "Head"
getgenv().InfiniteJump = false

-- [[ نظام الـ FOV ]]
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 2
FOVCircle.Color = Color3.fromRGB(138, 43, 226)
FOVCircle.Visible = false

game:GetService("RunService").RenderStepped:Connect(function()
    FOVCircle.Radius = getgenv().FOVRadius
    FOVCircle.Position = Vector2.new(game:GetService("UserInputService"):GetMouseLocation().X, game:GetService("UserInputService"):GetMouseLocation().Y)
    FOVCircle.Visible = getgenv().ShowFOV
end)

-- [[ الصفحات - Tabs ]]
local CombatTab = Window:CreateTab("Combat 🎯")
local RageTab = Window:CreateTab("Rage 🔥")
local VisualsTab = Window:CreateTab("Visuals 👁️")
local MoveTab = Window:CreateTab("Player 🏃")

-- [1] Combat
CombatTab:CreateToggle({
    Name = "Silent Aim",
    CurrentValue = false,
    Callback = function(Value) getgenv().SilentAimEnabled = Value end
})

CombatTab:CreateSlider({
    Name = "FOV Size",
    Range = {0, 800},
    Increment = 10,
    CurrentValue = 150,
    Callback = function(Value) getgenv().FOVRadius = Value end
})

-- [2] Visuals
VisualsTab:CreateButton({
    Name = "Full ESP (Highlights)",
    Callback = function()
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= game.Players.LocalPlayer and p.Character then
                local h = Instance.new("Highlight", p.Character)
                h.FillColor = Color3.fromRGB(138, 43, 226)
            end
        end
    end
})

-- [3] Movement
MoveTab:CreateSlider({
    Name = "Speed",
    Range = {16, 300},
    Increment = 10,
    CurrentValue = 16,
    Callback = function(Value) game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = Value end
})

MoveTab:CreateToggle({
    Name = "Infinite Jump",
    CurrentValue = false,
    Callback = function(Value) getgenv().InfiniteJump = Value end
})

-- معالجة القفز اللانهائي
game:GetService("UserInputService").JumpRequest:Connect(function()
    if getgenv().InfiniteJump then
        game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end
end)

Rayfield:Notify({Title = "SAAD BLASTR READY", Content = "تم الإصلاح بنجاح! استمتع بالسيطرة."})
