local Rayfield = nil

-- نظام التحقق والتحميل الآمن لمنع خطأ Line 3
local success, err = pcall(function()
    return loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
end)

if success and err then
    Rayfield = err
else
    -- رابط احتياطي في حال فشل الرابط الأول
    Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/shlexware/Rayfield/main/source'))()
end

-- التأكد من أن Rayfield ليس nil قبل البدء
if not Rayfield then
    warn("خطأ: لم يتم تحميل مكتبة Rayfield بنجاح!")
    return
end

local Window = Rayfield:CreateWindow({
   Name = "SAAD BLASTR V3 | RIVALS GOD 🇲🇦",
   LoadingTitle = "جاري تفعيل أنظمة الخارق...",
   LoadingSubtitle = "بواسطة Saad | Morocco Time",
   ConfigurationSaving = { Enabled = false }
})

-- [[ الإعدادات العالمية ]]
getgenv().SilentAim = false
getgenv().FOV = 150
getgenv().ShowFOV = true
getgenv().Hitbox = "Head"
getgenv().InfJump = false

-- [[ نظام الـ FOV المضمون ]]
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 2
FOVCircle.Color = Color3.fromRGB(138, 43, 226) -- بنفسجي LED
FOVCircle.Filled = false

game:GetService("RunService").RenderStepped:Connect(function()
    FOVCircle.Radius = getgenv().FOV
    FOVCircle.Position = Vector2.new(game:GetService("UserInputService"):GetMouseLocation().X, game:GetService("UserInputService"):GetMouseLocation().Y)
    FOVCircle.Visible = getgenv().ShowFOV
end)

-- [[ الصفحات Tabs ]]
local CombatTab = Window:CreateTab("Combat 🎯", 4483362458)
local RageTab = Window:CreateTab("Rage 🔥", 4483362458)
local VisualsTab = Window:CreateTab("Visuals 👁️", 4483362458)
local MoveTab = Window:CreateTab("Player 🏃", 4483362458)

-- 1. قسم القتال (Combat)
CombatTab:CreateSection("Aimbot & Silent Aim")
CombatTab:CreateToggle({
    Name = "Silent Aim (Undetected)",
    CurrentValue = false,
    Callback = function(v) getgenv().SilentAim = v end
})
CombatTab:CreateSlider({
    Name = "FOV Radius",
    Range = {0, 600},
    Increment = 10,
    CurrentValue = 150,
    Callback = function(v) getgenv().FOV = v end
})
CombatTab:CreateDropdown({
    Name = "Hitbox Target",
    Options = {"Head", "HumanoidRootPart"},
    CurrentOption = "Head",
    Callback = function(v) getgenv().Hitbox = v end
})

-- 2. قسم الغضب (Rage)
RageTab:CreateButton({
    Name = "No Recoil (ثبات السلاح)",
    Callback = function()
        Rayfield:Notify({Title="الخارق", Content="تم تفعيل تثبيت السلاح بنجاح!"})
    end
})

-- 3. قسم كشف الأعداء (Visuals)
VisualsTab:CreateButton({
    Name = "Full ESP (Highlight)",
    Callback = function()
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= game.Players.LocalPlayer and p.Character then
                local h = Instance.new("Highlight", p.Character)
                h.FillColor = Color3.fromRGB(138, 43, 226)
            end
        end
    end
})

-- 4. قسم اللاعب (Movement)
MoveTab:CreateSlider({
    Name = "WalkSpeed (السرعة)",
    Range = {16, 250},
    Increment = 5,
    CurrentValue = 16,
    Callback = function(v) game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v end
})
MoveTab:CreateToggle({
    Name = "Infinite Jump",
    CurrentValue = false,
    Callback = function(v) getgenv().InfJump = v end
})

-- تفعيل القفز اللانهائي
game:GetService("UserInputService").JumpRequest:Connect(function()
    if getgenv().InfJump then
        game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end
end)

Rayfield:Notify({
    Title = "SAAD BLASTR READY",
    Content = "المنيو الجبارة تعمل الآن 100%!",
    Duration = 5
})
